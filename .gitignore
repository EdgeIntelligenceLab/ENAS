# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.installed.cfg

# ── Virtual environments ──────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.python-version

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── TensorFlow / Keras ────────────────────────────────────────────────────
*.h5
*.keras
*.tflite
*.pb
saved_model/
checkpoints/

# ── ML artefacts ──────────────────────────────────────────────────────────
*.npy
*.npz
*.pkl
*.pth
*.pt

# ── Experiment outputs ────────────────────────────────────────────────────
results/raw_logs/*/
!results/raw_logs/.gitkeep
results/parsed_csv/*.csv
!results/parsed_csv/.gitkeep
results/models/*
!results/models/.gitkeep
results/single_runs/

# Keep summary tables for reviewers
!results/summary_tables/*.csv
!results/summary_tables/*.tex

# ── Generated figures ─────────────────────────────────────────────────────
figures/output/*.pdf
figures/output/*.png
figures/output/*.svg
!figures/output/.gitkeep

# ── Logs / temp ───────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Dataset files (too large for repository) ──────────────────────────────
datasets/vww/
datasets/melanoma/
datasets/coco/

# ── stm32tflm binary (must be downloaded separately) ──────────────────────
stm32tflm

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
*.swp

# ── ANONYMITY: never commit local paths or identifying info ───────────────
**/.local_paths.yaml
**/user_config.yaml
